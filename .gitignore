dist/
build/

# Dependencies and lock file: regenerated on each build
node_modules/
package-lock.json

# Editor and OS metadata
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# Runtime artefacts
*.log
.npm/
